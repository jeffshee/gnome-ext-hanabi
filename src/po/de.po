msgid "This feature requires Gtk 4.8 or above"
msgstr "Diese Funktion benötigt Gtk 4.8 oder höher"

#: src/prefs.js:445
msgid "Pause on Maximize or Fullscreen"
msgstr "Pause bei Maximieren oder Vollbildmodus"

#: src/prefs.js:447
msgid "Pause playback when there is maximized or fullscreen window"
msgstr "Wiedergabe bei maximiertem oder Vollbildfenster anhalten"

#: src/prefs.js:449
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Niemals</b>: Disable this feature.\n"
"    <b>Beliebiger Bildschirm</b>: Wiedergabe bei maximiertem oder "
"Vollbildfenster auf einem beliebigen Bildschirm anhalten.\n"
"    <b>Alle Bildschirme</b>: Wiedergabe bei maximiertem oder Vollbildfenster "
"auf allen Bildschirm anhalten.\n"
"    "

#: src/prefs.js:456 src/prefs.js:489
msgid "Never"
msgstr "Niemals"

#: src/prefs.js:457
msgid "Any Monitor"
msgstr "Beliebiger Bildschirm"

#: src/prefs.js:458
msgid "All Monitors"
msgstr "Alle Bildschirme"

#: src/prefs.js:478
msgid "Pause on Battery"
msgstr "Pause bei Batteriebetrieb"

#: src/prefs.js:480
msgid "Pause playback when the device is on battery or the battery is low"
msgstr ""
"Pausieren der Wiedergabe im Batteriebetrieb oder bei niedrigem Batteriestand"

#: src/prefs.js:482
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Niemals</b>: Deaktiviert die Funktion.\n"
"    <b>Niedriger Batteriestand</b>: Pausieren der Wiedergabe bei niedrigem "
"Batteriestand (Unter dem Schwellwert).\n"
"    <b>Immer</b>: Pausieren der Wiedergabe im Batteriebetrieb.\n"
"    "

#: src/prefs.js:490
msgid "Low Battery"
msgstr "Niedriger Batteriestand"

#: src/prefs.js:491
msgid "Always"
msgstr "Immer"

#: src/prefs.js:511
msgid "Change Wallpaper Mode"
msgstr "Modus des Hintergrundbildes ändern"

#: src/prefs.js:512
msgid "Control how to change wallpapers automatically"
msgstr "Steuere, wie sich das Hintergrundbild automatisch ändert"

#: src/prefs.js:513
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Sequenz:</b> Übernimmt die Verzeichnisreihenfolge (absteigend).\n"
"    <b>Umgekehrte Sequenz:</b> Übernimmt die Verzeichnisreihenfolge "
"(aufsteigend).\n"
"    <b>Zufall:</b> Wählt zufällig Hintergrundbilder aus dem Verzeichnis "
"aus.\n"
"    "

