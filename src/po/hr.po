#: src/prefs.js:430
msgid "Pause on Maximize or Fullscreen"
msgstr "Zaustavi Video u Fullscreen-u"

#: src/prefs.js:432
msgid "Pause playback when there is maximized or fullscreen window"
msgstr ""

#: src/prefs.js:434
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Nikad</b>: Isključi ovu funkcionalnost.\n"
"    <b>Jedan Monitor</b>: Zaustavi video kada je na jednom od monitora "
"maksimiziran prozor preko cijelog ekrana.\n"
"    <b>Svi Monitori</b>: Zaustavi video kada su na svim monitorima "
"maksimiziran prozori preko cijelog ekrana.\n"
"    "

