#: src/prefs.js:400
msgid "Fit Mode"
msgstr "Mód vyplnění"

#: src/prefs.js:401
msgid "Control how wallpaper fits within the monitor"
msgstr "Nastavit jak se pozadí vejde do obrazovky"

#: src/prefs.js:402
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Roztáhnout</b>: Roztáhne tapetu aby vyplnila celou obrazovku.\n"
"    <b>Obsáhnout</b>: Škáluje tapetu aby se vešla na obrazovku (zachová "
"poměr stran).\n"
"    <b>Vyplnit</b>: Škáluje tapetu aby vyplnila obrazovku (zachová poměr "
"stran).\n"
"    <b>Škálovat dolů</b>: Zmenšit tapetu aby se vešla na obrazovku pokud je "
"třeba, jinak ponechat v původní velikosti\n"
"    "

#: src/prefs.js:410
msgid "Fill"
msgstr "Roztáhnout"

#: src/prefs.js:411
msgid "Contain"
msgstr "Obsáhnout"

#: src/prefs.js:412
msgid "Cover"
msgstr "Vyplnit"

#: src/prefs.js:413
msgid "Scale-down"
msgstr "Škálovat dolů"

#: src/prefs.js:426
msgid "This feature requires Gtk 4.8 or above"
msgstr "Tato funkce požaduje Gtk 4.8 nebo novější"

#: src/prefs.js:438
msgid "Pause on Maximize or Fullscreen"
msgstr "Zastavit při maximalizovaném/fullscreen okně."

#: src/prefs.js:440
msgid "Pause playback when there is maximized or fullscreen window"
msgstr ""
"Zastavit přehrávání jestli je okno maximalizováno nebo na plnou obrazovku."

#: src/prefs.js:442
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Nikdy</b>: Nevypínejte tuto funkci.\n"
"    <b>Jakákoliv obrazovka</b>: Zastavit přehrávání pokud na jakékoliv "
"obrazovce je maximizované/fullscreen okno.\n"
"    <b>Všechny obrazovky</b>: Zastavit přehrávání pokud na všech obrazovkách "
"jsou maximalizované/fullscreen okna.\n"
"    "

#: src/prefs.js:449 src/prefs.js:482
msgid "Never"
msgstr "Nikdy"

#: src/prefs.js:450
msgid "Any Monitor"
msgstr "Jakákoliv obrazovka"

#: src/prefs.js:451
msgid "All Monitors"
msgstr "Všechny obrazovky."

#: src/prefs.js:471
msgid "Pause on Battery"
msgstr "Zastavit na baterii"

#: src/prefs.js:473
msgid "Pause playback when the device is on battery or the battery is low"
msgstr ""
"Zastavit přehrávání jestli je zařízení na baterii nebo je baterie nízká"

#: src/prefs.js:475
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Nikdy</b>: Nezakazujte tuto funkci\n"
"    <b>Nízká baterie</b>: Zastavit přehrávání pokud má zařízení nízko "
"nabitou baterii (Pod hranicí).\n"
"    <b>Vždy</b>: Zastavit přehrávání jestli je zařízení napájeno z baterie.\n"
"    "

#: src/prefs.js:483
msgid "Low Battery"
msgstr "Nízká baterie"

#: src/prefs.js:484
msgid "Always"
msgstr "Vždy"

#: src/prefs.js:504
msgid "Change Wallpaper Mode"
msgstr "Změnit mód tapety."

#: src/prefs.js:505
msgid "Control how to change wallpapers automatically"
msgstr "Ovládat jak se tapety mění automaticky"

#: src/prefs.js:506
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Sekvenční:</b> Zanechat sekvenci složek (padající seřazení)\n"
"    <b>Opačně sekvenční:</b> Vybírat tapety v opačné sekvenci (stoupající "
"seřazení)\n"
"    <b>Náhodně:</b> Náhodně vybrat tapety ze složky\n"
"    "

