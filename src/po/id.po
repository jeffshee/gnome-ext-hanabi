#: src/prefs.js:392
msgid "Fit Mode"
msgstr ""

#: src/prefs.js:393
msgid "Control how wallpaper fits within the monitor"
msgstr "Kontrol bagaimana wallpaper dapat sesuai di monitor"

#: src/prefs.js:394
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Fill</b>: Regangkan latar belakang untuk memenuhi monitor.\n"
"<b>Contain</b>: Perbesar latar belakang agar sesuai dengan monitor (rasio "
"aspek yang tajam).\n"
"<b>Cover</b>: Ukur latar belakang untuk menutupi monitor (rasio aspek "
"tajam).\n"
"<b>Scale-down</b>: Meningkatkan latar belakang agar sesuai dengan monitor "
"jika diperlukan. Jika tidak, menjaga ukuran asli latar belakang.\n"
".\n"
"    "

#: src/prefs.js:402
msgid "Fill"
msgstr "Penuh"

#: src/prefs.js:403
msgid "Contain"
msgstr "Perbesar"

#: src/prefs.js:404
msgid "Cover"
msgstr "Menutup"

#: src/prefs.js:405
msgid "Scale-down"
msgstr "Turunkan"

#: src/prefs.js:418
msgid "This feature requires Gtk 4.8 or above"
msgstr "FItur ini memerlukan Gtk 4.8 atau diatasnya"

#: src/prefs.js:430
msgid "Pause on Maximize or Fullscreen"
msgstr "Jeda saat jendela maksimal atau layar penuh"

#: src/prefs.js:432
msgid "Pause playback when there is maximized or fullscreen window"
msgstr "Jeda pemutaran ketika  jendela maksimum atau layar penuh"

#: src/prefs.js:434
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Tidak pernah</b>: Nonaktifkan fitur ini.\n"
"    <b>Monitor Apa pun</b>: Jeda video ketika ada jendela yang dimaksimalkan "
"atau layar penuh pada monitor apa pun.\n"
"    <b>Semua Monitor</b>: Jeda video ketika ada jendela yang dimaksimalkan "
"atau layar penuh pada semua monitor.\n"
"    "

#: src/prefs.js:441 src/prefs.js:474
msgid "Never"
msgstr "Jangan Pernah"

#: src/prefs.js:442
msgid "Any Monitor"
msgstr "Monitor apa pun"

#: src/prefs.js:443
msgid "All Monitors"
msgstr "Semua Monitor"

#: src/prefs.js:463
msgid "Pause on Battery"
msgstr "Jeda saat menggunakan baterai"

#: src/prefs.js:465
msgid "Pause playback when the device is on battery or the battery is low"
msgstr "Jeda video jika perangkat menggunakan baterai atau baterai lemah"

#: src/prefs.js:467
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Tidak pernah</b>: Nonaktifkan fitur ini.\n"
"    <b>Baterai Lemah</b>: Jeda video saat perangkat dalam kondisi baterai "
"lemah (di bawah batas).\n"
"    <b>Selalu</b>: Jeda video saat perangkat menggunakan baterai.\n"
"    "

#: src/prefs.js:475
msgid "Low Battery"
msgstr "Baterai Rendah"

#: src/prefs.js:476
msgid "Always"
msgstr "Selalu"

#: src/prefs.js:496
msgid "Change Wallpaper Mode"
msgstr "Ubah Mode Wallpaper"

#: src/prefs.js:497
msgid "Control how to change wallpapers automatically"
msgstr "Kontrol bagaimana cara untuk mengubah latar belakang secara otomatis"

#: src/prefs.js:498
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Sequential:</b> Pertahankan urutan direktori (urutan menurun).\n"
"    <b>Inverse Sequential:</b> Ambil wallpaper dalam urutan yang berlawanan "
"(urutan menaik).\n"
"    <b>Acak:</b> Pilih wallpaper secara acak dari direktori.\n"
"    "

#: src/prefs.js:505
msgid "Sequential"
msgstr "Berurutan"

#: src/prefs.js:506
msgid "Inverse Sequential"
msgstr "Berurutan Terbalik"

#: src/prefs.js:507
msgid "Random"
msgstr "Acak"

