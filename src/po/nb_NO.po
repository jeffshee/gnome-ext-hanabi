#: src/prefs.js:402
#, fuzzy
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Fyll</b>: Strekk bakgrunnsbildet for å fylle skjermen.\n"
"    <b>Tilpass</b>: Skaler bakgrunnsbildet til å passe skjermen (side "
"retning forhold er beholdt).\n"
"    <b>Omslag</b>: Skaler bakgrunnsbildet til å dekke skjermen (side retning "
"forhold er beholdt).\n"
"    <b>Skaler ned</b>: Skaler ned til bakgrunnsbildet for å fylle skjermen "
"ved behov. Ellers blir opprinnelig størrelse beholdt.\n"
"    "

