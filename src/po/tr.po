msgid "Fit Mode"
msgstr "Doldurma Kipi"

#: src/prefs.js:408
msgid "Control how wallpaper fits within the monitor"
msgstr "Duvar kağıdının ekrana nasıl sığdığını denetle"

#: src/prefs.js:409
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Doldur</b>: Duvar kağıdını ekranı dolduracak şekilde uzat.\n"
"   <b>İçer</b>: Duvar kağıdını ekrana sığacak şekilde ölçeklendir (en boy "
"oranını koru).\n"
"   <b>Kapla</b>: Duvar kağıdını ekranı kaplayacak şekilde ölçeklendir (en "
"boy oranını koru).\n"
"   <b>Küçült</b>: Gerekirse duvar kağıdını ekrana sığacak şekilde küçült, "
"aksi takdirde özgün boyutu koru.\n"
"    "

#: src/prefs.js:417
msgid "Fill"
msgstr "Doldur"

#: src/prefs.js:418
msgid "Contain"
msgstr "İçer"

#: src/prefs.js:419
msgid "Cover"
msgstr "Kapla"

#: src/prefs.js:420
msgid "Scale-down"
msgstr "Küçült"

#: src/prefs.js:433
msgid "This feature requires Gtk 4.8 or above"
msgstr "Bu özellik Gtk 4.8 veya üst sürümü gerektirir"

#: src/prefs.js:445
msgid "Pause on Maximize or Fullscreen"
msgstr "Tam veya Büyütülmüş Pencerede Duraklat"

#: src/prefs.js:447
msgid "Pause playback when there is maximized or fullscreen window"
msgstr "Büyütülmüş veya tam ekran pencere olduğunda oynatmayı duraklat"

#: src/prefs.js:449
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Asla</b>: Bu özelliği kapat.\n"
"    <b>Herhangi Monitor</b>: Herhangi bir monitörde tam ekran veya "
"büyütülmüş bir pencere varsa oynatmayı durdur.\n"
"    <b>All Monitors</b>: Bütün monitörlerde tam ekran veya büyütülmüş bir "
"pencere varsa oynatmayı durdur.\n"
"    "

#: src/prefs.js:456 src/prefs.js:489
msgid "Never"
msgstr "Asla"

#: src/prefs.js:457
msgid "Any Monitor"
msgstr "Herhangi Monitor"

#: src/prefs.js:458
msgid "All Monitors"
msgstr "Bütün Ekranlar"

#: src/prefs.js:478
msgid "Pause on Battery"
msgstr "Batarya durumunda duraklat"

#: src/prefs.js:480
msgid "Pause playback when the device is on battery or the battery is low"
msgstr ""
"Bilgisayar batarya durumunda veya düşük bataryada ise oynatmayı durdur."

#: src/prefs.js:482
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Asla</b>: Bu özelliği kapat.\n"
"    <b>Düşük batarya</b>: Batarya düşük güçte(belirlenen seviyenin altında) "
"ise oynatmayı durdur.\n"
"    <b>Her zaman</b>: Bilgisayar güce takılı değil ise oynatmayı durdur.\n"
"    "

#: src/prefs.js:490
msgid "Low Battery"
msgstr "Düşük Batarya"

#: src/prefs.js:491
msgid "Always"
msgstr "Her zaman"

#: src/prefs.js:511
msgid "Change Wallpaper Mode"
msgstr "Duvar Kağıdı Kipini Değiştir"

#: src/prefs.js:512
msgid "Control how to change wallpapers automatically"
msgstr "Duvar kağıtlarını otomatik olarak nasıl değiştirileceğini ayarlayın."

#: src/prefs.js:513
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Ardışık:</b> Dizin sırasını koru (A-Z).\n"
"    <b>Ters Ardışık:</b> Dizin sırasını koru (Z-A).\n"
"    <b>Rastgele:</b> Dizinden rastgele duvar kağıdı seç.\n"
"    "

#: src/prefs.js:520
msgid "Sequential"
msgstr "Ardışık"

#: src/prefs.js:521
