msgstr "Este recurso requer Gtk 4.8 ou superior"

#: src/prefs.js:445
msgid "Pause on Maximize or Fullscreen"
msgstr "Pausar ao Maximizar ou em Tela Cheia"

#: src/prefs.js:447
msgid "Pause playback when there is maximized or fullscreen window"
msgstr ""
"Pausar a reprodução quando houver uma janela maximizada ou em tela cheia"

#: src/prefs.js:449
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Nunca<b>: Desabilitar este recurso.\n"
"    <b>Qualquer Monitor<b>: Pausar a reprodução quando houver uma janela "
"maximizada ou em tela cheia em algum dos monitores\n"
"    <b>Todos os Monitores<b>:Pausar a reprodução quando houver uma janelas "
"maximizadas ou em tela cheia em todos dos monitores\n"
"    "

#: src/prefs.js:456 src/prefs.js:489
msgid "Never"
msgstr "Nunca"

#: src/prefs.js:457
msgid "Any Monitor"
msgstr "Qualquer Monitor"

#: src/prefs.js:458
msgid "All Monitors"
msgstr "Todos os Monitores"

#: src/prefs.js:478
msgid "Pause on Battery"
msgstr "Pausar no modo Bateria"

#: src/prefs.js:480
msgid "Pause playback when the device is on battery or the battery is low"
msgstr ""
"Pausar a reprodução quando o dispositivo estiver na bateria ou estiver com "
"baixa bateria."

#: src/prefs.js:482
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Nunca<b>: Desabilitar este recurso.\n"
"    <b>Baixa Bateria<b>: Pausar a reprodução quando o dispositivo estiver no "
"modo Baixa Bateria (abaixo do limite definido).\n"
"    <b>Sempre<b>: Pausar a reprodução quando o dispositivo estiver usando "
"bateria.\n"
"    "

#: src/prefs.js:490
msgid "Low Battery"
msgstr "Baixa Bateria"

#: src/prefs.js:491
msgid "Always"
msgstr "Sempre"

#: src/prefs.js:511
msgid "Change Wallpaper Mode"
msgstr "Alterar o modo do papel de parede"

#: src/prefs.js:512
msgid "Control how to change wallpapers automatically"
msgstr "Controlar como mudar os papeis de parede automaticamente"

#: src/prefs.js:513
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Sequencial:</b> Preservar a sequência do diretório (ordem "
"decrescente).\n"
"    <b>Sequencial Inverso:</b> Reagrupar papéis de parede na sequência "
"oposta (ordem crescente).\n"
"    <b>Aleatório:</b> Selecionar papéis de parede do diretório "
"aleatoriamente.\n"
"    "

