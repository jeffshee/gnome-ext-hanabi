#: src/prefs.js:407
msgid "Fit Mode"
msgstr "Ajuste do Wallpaper"

#: src/prefs.js:408
msgid "Control how wallpaper fits within the monitor"
msgstr "Controlar como o papel de parede se ajusta ao monitor"

#: src/prefs.js:409
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Preencher</b>: Esticar o papel de parede para preencher o monitor.\n"
"    <b>Conter</b>: Redimensionar o papel de parede para caber no monitor "
"(mantém a proporção).\n"
"    <b>Cobrir</b>: Redimensionar o papel de parede para cobrir o monitor "
"(mantém a proporção).\n"
"    <b>Reduzir</b>: Reduzir o papel de parede para caber no monitor, se "
"necessário; caso contrário, manter o tamanho original.\n"
"    "

#: src/prefs.js:417
msgid "Fill"
