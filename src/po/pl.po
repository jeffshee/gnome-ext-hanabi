#: src/prefs.js:400
msgid "Fit Mode"
msgstr "Tryb Dopasowania"

#: src/prefs.js:401
msgid "Control how wallpaper fits within the monitor"
msgstr "Kontroluje sposób dopasowania tapety do monitora"

#: src/prefs.js:402
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Wypełnij</b>: Rozciągnij tapetę aby wypełnić ekran.\n"
"    <b>Dopasuj</b>: Przeskaluj tapetę aby dopasować ją do ekranu (bez zmian "
"proporcji).\n"
"    <b>Rozciągnij</b>: Przeskaluj tapetę aby pokryć ekran (bez zmian "
"proporcji).\n"
"    <b>Zmniejsz w skali</b>: W razie potrzeby zmniejsza skalę tapety aby "
"dopasować ją do ekranu\n"
"    "

#: src/prefs.js:410
msgid "Fill"
msgstr "Wypełnij"

#: src/prefs.js:411
msgid "Contain"
msgstr "Dopasuj"

#: src/prefs.js:412
msgid "Cover"
msgstr "Rozciągnij"

#: src/prefs.js:413
msgid "Scale-down"
msgstr "Zmniejsz w skali"

#: src/prefs.js:426
msgid "This feature requires Gtk 4.8 or above"
msgstr "Ta funkcja wymaga wersji Gtk 4.8 lub wyżej"

#: src/prefs.js:438
msgid "Pause on Maximize or Fullscreen"
msgstr "Zatrzymaj przy Pełnym Ekranie"

#: src/prefs.js:440
msgid "Pause playback when there is maximized or fullscreen window"
msgstr "Zatrzymaj odtwarzanie, gdy okno pokrywa cały ekran"

#: src/prefs.js:442
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Any Monitor</b>: Pause playback when there is maximized or fullscreen "
"window on any monitor.\n"
"    <b>All Monitors</b>: Pause playback when there are maximized or "
"fullscreen windows on all monitors.\n"
"    "
msgstr ""
"\n"
"    <b>Nigdy</b>: Wyłącz tę funkcję.\n"
"    <b>Jeden z Ekranów</b>: Zatrzymaj odtwarzanie, gdy na jednym z ekranów "
"otwarta jest aplikacja pełnoekranowa.\n"
"    <b>Wszystkie Ekrany</b>: Zatrzymaj odtwarzanie, gdy na wszystkich "
"ekranach otwarte są aplikacje pełnoekranowe.\n"
"    "

#: src/prefs.js:449 src/prefs.js:482
msgid "Never"
msgstr "Nigdy"

#: src/prefs.js:450
msgid "Any Monitor"
msgstr "Jeden z Ekranów"

#: src/prefs.js:451
msgid "All Monitors"
msgstr "Wszystkie Ekrany"

#: src/prefs.js:471
msgid "Pause on Battery"
msgstr "Zatrzymaj na Baterii"

#: src/prefs.js:473
msgid "Pause playback when the device is on battery or the battery is low"
msgstr "Zatrzymaj odtwarzanie w zależności od stanu baterii"

#: src/prefs.js:475
msgid ""
"\n"
"    <b>Never</b>: Disable this feature.\n"
"    <b>Low Battery</b>: Pause playback when the device is on low battery "
"(below the threshold).\n"
"    <b>Always</b>: Pause playback when the device is on battery.\n"
"    "
msgstr ""
"\n"
"    <b>Nigdy</b>: Wyłącz tę funkcję.\n"
"    <b>Słaba Bateria</b>: Zatrzymaj odtwarzanie, gdy poziom baterii jest "
"niski.\n"
"    <b>Zawsze</b>: Zatrzymaj odtwarzanie, gdy urządzenie jest zasilane z "
"baterii.\n"
"    "

#: src/prefs.js:483
msgid "Low Battery"
msgstr "Słaba Bateria"

#: src/prefs.js:484
msgid "Always"
msgstr "Zawsze"

#: src/prefs.js:504
msgid "Change Wallpaper Mode"
msgstr "Zmień Tryb Zmian Tapety"

#: src/prefs.js:505
msgid "Control how to change wallpapers automatically"
msgstr "Kontroluje w jaki sposób tapety powinny się zmieniać"

#: src/prefs.js:506
msgid ""
"\n"
"    <b>Sequential:</b> Preserve the directory sequence (descending order).\n"
"    <b>Inverse Sequential:</b> Retrieve wallpapers in the opposite sequence "
"(ascending order).\n"
"    <b>Random:</b> Randomly select wallpapers from the directory.\n"
"    "
msgstr ""
"\n"
"    <b>Sekwencyjnie:</b> Zachowaj kolejność folderu (malejąco).\n"
"    <b>Sekwencyjnie (od tyłu):</b> Zachowaj odwrotną kolejność folderu "
"(rosnąco).\n"
"    <b>Losowo:</b> Losowo wybieraj tapety z folderu.\n"
"    "

#: src/prefs.js:513
msgid "Sequential"
msgstr "Sekwencyjnie"

#: src/prefs.js:514
msgid "Inverse Sequential"
msgstr "Sekwencyjnie (od tyłu)"

#: src/prefs.js:515
msgid "Random"
msgstr "Losowo"

