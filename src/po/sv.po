#: src/prefs.js:407
msgid "Fit Mode"
msgstr ""

#: src/prefs.js:408
msgid "Control how wallpaper fits within the monitor"
msgstr "Kontrollera hur bakgrunden får plats inom bildskärmen"

#: src/prefs.js:409
msgid ""
"\n"
"    <b>Fill</b>: Stretch the wallpaper to fill the monitor.\n"
"    <b>Contain</b>: Scale the wallpaper to fit the monitor (keep aspect "
"ratio).\n"
"    <b>Cover</b>: Scale the wallpaper to cover the monitor (keep aspect "
"ratio).\n"
"    <b>Scale-down</b>: Scale down the wallpaper to fit the monitor if "
"needed, otherwise keep its original size.\n"
"    "
msgstr ""
"\n"
"    <b>Fyll</b>: Sträck bakgrunden för att fylla bildskärmen\n"
"    <b>Innehåll</b>: Skala bakgrunden för att passa bildskärmen (Behåll "
"bildförhållande).\n"
"    <b>Täck</b>: Skala bakgrunden för att täcka bildskärmen (Behåll "
"bildförhållande).\n"
"    <b>Skala-Ner</b>: Skala ner bakgrunden för att passa bildskärmen ifall "
"det behövs, behåll annars dess ursprungliga storlek\n"
"    "

#: src/prefs.js:417
msgid "Fill"
msgstr "Fyll"

#: src/prefs.js:418
msgid "Contain"
msgstr "Innehålla"

#: src/prefs.js:419
